# ================================================================
# EDMS 後端環境變數範本（本機開發用）
# 複製為 .env 後填入實際值。.env 不進 git。
# ================================================================

# ── 應用程式 ────────────────────────────────────────────────────
APP_NAME=EDMS
DEBUG=false

# ── CORS ────────────────────────────────────────────────────────
# 多個 origin 用逗號分隔，例如：http://localhost:5173,https://edms.example.com
CORS_ORIGINS=http://localhost:5173

# ── 資料庫（PostgreSQL）────────────────────────────────────────
# 本機開發：host 為 localhost；填入你 postgres 帳號的密碼與已建立的 edms 資料庫
DATABASE_URL=postgresql+asyncpg://postgres:change-me@localhost:5432/edms

# 連線池設定（一般不需修改）
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_RECYCLE=1800

# ── 認證 / 加密 / 寄信設定 ─────────────────────────────────────
# JWT_SECRET_KEY、ENCRYPTION_KEY、MAIL_*、FRONTEND_URL 等，
# 於「認證 task」引入 auth 模組時再一併補上。
