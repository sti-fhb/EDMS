# ================================================================
# EDMS 後端環境變數範本（本機開發用）
# 複製為 .env 後填入實際值。.env 不進 git。
# ================================================================

# ── 應用程式 ────────────────────────────────────────────────────
APP_NAME=EDMS
DEBUG=false

# ── CORS ────────────────────────────────────────────────────────
# 多個 origin 用逗號分隔，例如：http://localhost:5173,https://edms.example.com
CORS_ORIGINS=http://localhost:5173

# 前端公開 base URL（組信中連結，如密碼重設頁 {FRONTEND_BASE_URL}/reset-password?token=...）
FRONTEND_BASE_URL=http://localhost:5173

# ── 資料庫（PostgreSQL）────────────────────────────────────────
# 本機開發：host 為 localhost；填入你 postgres 帳號的密碼與已建立的 edms 資料庫
DATABASE_URL=postgresql+asyncpg://postgres:change-me@localhost:5432/edms

# 連線池設定（一般不需修改）
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_RECYCLE=1800

# ── 認證（簡單 JWT）────────────────────────────────────────────
# 必填：各環境獨立產生（如 `openssl rand -hex 32`），不進 git。
JWT_SECRET_KEY=change-me-generate-per-environment
# JWT_ALGORITHM=HS256

# ── 寄信（SMTP，平台發信引擎用；可留空，發信功能上線前再設）────────
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM=noreply@edms.local
# MAIL_STARTTLS=true
# MAIL_SSL_TLS=false          # implicit TLS（埠 465）；與 STARTTLS 互斥
# MAIL_SUPPRESS_SEND=false    # 測試 / E2E 跳過實際寄送
